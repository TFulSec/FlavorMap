const express = require('express');
const app = express();
app.use(express.json()); // Để đọc được dữ liệu JSON từ Frontend gửi lên

// Giả lập cơ sở dữ liệu user hệ thống ẩm thực
const USERS = [
    { username: "hung_amthuc", password: "password123", name: "Lê Tiến Hưng" }
];

// 1. [POST] API ĐĂNG NHẬP (Issue #23)
app.post('/api/login', (req, res) => {
    const { username, password } = req.body;

    // Tìm user trong database
    const user = USERS.find(u => u.username === username && u.password === password);

    if (user) {
        // Đăng nhập thành công -> Trả về thông tin và Token giả lập (Session)
        res.status(200).json({
            success: true,
            message: "Đăng nhập thành công!",
            token: "fake-jwt-token-xyz123",
            user: { name: user.name, username: user.username }
        });
    } else {
        // Thất bại
        res.status(401).json({
            success: false,
            message: "Sai tài khoản hoặc mật khẩu rồi bạn ơi!"
        });
    }
});

// 2. [POST] API ĐĂNG XUẤT (Issue #24)
app.post('/api/logout', (req, res) => {
    // Logic đăng xuất: Xóa session hoặc vô hiệu hóa token
    res.status(200).json({
        success: true,
        message: "Đăng xuất thành công! Hẹn gặp lại bạn."
    });
});

app.listen(5000, () => console.log("Backend đang chạy ở port 5000"));