<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>FlavorMap - Đăng Nhập Khám Phá Ẩm Thực</title>
    <style>
        body { font-family: Arial, sans-serif; background: #f4f4f4; display: flex; justify-content: center; align-items: center; height: 100vh; }
        .login-card { background: white; padding: 30px; border-radius: 8px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); width: 320px; }
        .login-card h2 { text-align: center; color: #ff5722; margin-bottom: 20px; }
        .form-group { margin-bottom: 15px; }
        .form-group label { display: block; margin-bottom: 5px; }
        .form-group input { width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px; box-sizing: border-box; }
        .btn { width: 100%; padding: 10px; background: #ff5722; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 16px; }
        .btn:hover { background: #e64a19; }
        #message { text-align: center; margin-top: 15px; font-weight: bold; }
    </style>
</head>
<body>

<div class="login-card">
    <h2>FlavorMap 🍜</h2>
    <form id="loginForm">
        <div class="form-group">
            <label>Tài khoản:</label>
            <input type="text" id="username" placeholder="Nhập tên đăng nhập..." required>
        </div>
        <div class="form-group">
            <label>Mật khẩu:</label>
            <input type="password" id="password" placeholder="Nhập mật khẩu..." required>
        </div>
        <button type="submit" class="btn">Đăng nhập</button>
    </form>
    <div id="message"></div>
</div>

<script>
    document.getElementById('loginForm').addEventListener('submit', async (e) => {
        e.preventDefault(); // Ngăn trang web bị reload lại
        
        const username = document.getElementById('username').value;
        const password = document.getElementById('password').value;
        const messageDiv = document.getElementById('message');

        try {
            // Gửi dữ liệu lên API Backend
            const response = await fetch('http://localhost:5000/api/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username, password })
            });

            const data = await response.json();

            if (data.success) {
                messageDiv.style.color = "green";
                messageDiv.innerText = `Chào mừng ${data.user.name}!`;
                
                // LƯU TRẠNG THÁI: Lưu token và tên user vào máy để duy trì đăng nhập (Issue #25)
                localStorage.setItem('token', data.token);
                localStorage.setItem('user_name', data.user.name);

                // Chuyển hướng về trang chủ bản đồ ẩm thực sau 1.5 giây
                setTimeout(() => { window.location.href = 'index.html'; }, 1500);
            } else {
                messageDiv.style.color = "red";
                messageDiv.innerText = data.message;
            }
        } catch (error) {
            messageDiv.style.color = "red";
            messageDiv.innerText = "Lỗi kết nối đến server rồi!";
        }
    });
</script>
</body>
</html>